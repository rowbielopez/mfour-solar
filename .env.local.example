# ─────────────────────────────────────────────────
#  Contact Form — SMTP Configuration
#  Copy this file to .env.local and fill in values.
#  .env.local is git-ignored and never committed.
# ─────────────────────────────────────────────────

# SMTP server settings
# For Gmail: host=smtp.gmail.com, port=587, secure=false
#   → In Gmail, enable 2FA then create an App Password at
#     https://myaccount.google.com/apppasswords
# For Yahoo Mail: host=smtp.mail.yahoo.com, port=587, secure=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# The email account used to SEND messages
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password

# Override the business inbox that receives quote requests
# Defaults to jua_electrical_services@yahoo.com if not set
CONTACT_TO_EMAIL=jua_electrical_services@yahoo.com
